# Copy this to .env.local and fill in your values
# .env.local is gitignored — NEVER commit actual credentials

# MongoDB (local dev)
MONGODB_URI=mongodb://127.0.0.1:27017/smashuniversz
# MongoDB (production Atlas) — set in Vercel dashboard instead
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smashuniversz

NEXTAUTH_SECRET=generate-at-https://generate-secret.vercel.app/32
NEXTAUTH_URL=http://localhost:3000

RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=webhook_secret

# WhatsApp provider: 'meta' (cheap, ~Rs35/month for 100 members) or 'wati'
WHATSAPP_PROVIDER=meta

# Meta Cloud API credentials (developers.facebook.com)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token

# WATI (only if WHATSAPP_PROVIDER=wati)
# WATI_API_ENDPOINT=https://live-server.wati.io
# WATI_API_TOKEN=your_wati_token

NEXT_PUBLIC_URL=http://localhost:3000
CRON_SECRET=your-random-cron-secret
